ENVIRONMENT=production

# Use the pooled/transaction connection string from Neon or Supabase.
# Add sslmode=require if your provider does not include it in the URL.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require

# Generate a long random value before deploy.
JWT_SECRET=replace-with-a-long-random-secret-32-bytes-or-more
JWT_EXPIRES_MINUTES=480

# Replace with the final Vercel app URL after frontend deploy.
CORS_ORIGINS=https://your-frontend-app.vercel.app

OCSVM_MODEL_PATH=/app/src/ml/weights/ocsvm_cert_r42_chunked.joblib
OCSVM_MODEL_VERSION=ocsvm-cert-r42-chunked
ML_MODEL_PATH=/app/src/ml/weights
ML_ARTIFACT_PATH=/app/artifacts

# Optional. Leave empty to use rule-based fallback explanations.
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest
MISTRAL_CHAT_COMPLETIONS_URL=https://api.mistral.ai/v1/chat/completions

NORMALIZER_ENABLED=true
ML_SCORING_ENABLED=true
