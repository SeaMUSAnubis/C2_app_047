POSTGRES_USER=ueba_user
POSTGRES_PASSWORD=ueba_password
POSTGRES_DB=ueba_db
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
PGDATA=/var/lib/postgresql/data/app_pg17

FRONTEND_PORT=5173

VITE_API_BASE_URL=/api

DATABASE_URL=postgresql://ueba_user:ueba_password@127.0.0.1:5432/ueba_db
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_MINUTES=480
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
FRONTEND_DIST_DIR=/app/src/frontend/dist

ML_MODEL_PATH=src/ml/weights
ML_ARTIFACT_PATH=artifacts
OCSVM_MODEL_PATH=src/ml/weights/ocsvm_cert_r42_chunked.joblib
OCSVM_MODEL_VERSION=ocsvm-cert-r42-chunked

MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest
MISTRAL_CHAT_COMPLETIONS_URL=https://api.mistral.ai/v1/chat/completions
