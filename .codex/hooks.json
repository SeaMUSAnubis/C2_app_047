{
  "version": "1.0",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "name": "log-prompt",
            "command": "bash scripts/_pyrun.sh scripts/log_hook.py --tool=codex",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "name": "log-stop",
            "command": "bash scripts/_pyrun.sh scripts/log_hook.py --tool=codex",
            "timeout": 10
          },
          {
            "type": "command",
            "name": "auto-git-commit-push",
            "command": "bash scripts/auto_commit_push.sh",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
