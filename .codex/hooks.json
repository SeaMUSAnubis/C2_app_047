{
  "hooks": {
    "UserPromptSubmit": [
      {
        "type": "command",
        "name": "log-prompt",
        "command": "bash scripts/_pyrun.sh scripts/log_hook.py --tool=codex",
        "timeout": 10
      }
    ],
    "Stop": [
      {
        "type": "command",
        "name": "log-stop",
        "command": "bash scripts/_pyrun.sh scripts/log_hook.py --tool=codex",
        "timeout": 10
      },
      {
        "type": "command",
        "name": "auto-commit-push",
        "command": "bash scripts/auto_commit_push.sh",
        "timeout": 60
      }
    ]
  }
}
